@@ -777,6 +782,38 @@ - (void) updateUIInfo
     });
 }
 
+/*
+ * ClassicMac: push the current window size to the guest again, for when the
+ * guest missed (or has not yet acted on) the previous resolution request -
+ * e.g. the Display Manager was still starting up, or the driver's poll
+ * debounce swallowed it.
+ */
+- (void) resendUIInfo
+{
+    if (!allow_events) {
+        return;
+    }
+
+    with_bql(^{
+        if (!qemu_console_is_graphic(dcl.con) ||
+            !dpy_ui_info_supported(dcl.con)) {
+            return;
+        }
+        /*
+         * dpy_set_ui_info() drops updates identical to the last one it
+         * stored, so first nudge a field the guest does not act on. The
+         * console's ui_info timer coalesces the two calls into a single
+         * delivery of the real values, and the display device (nubus-qfb or
+         * the host-resize VGA) bumps its request serial, making the guest
+         * driver re-apply the resolution even if nothing changed host-side.
+         */
+        QemuUIInfo nudge = *dpy_get_ui_info(dcl.con);
+        nudge.xoff ^= 1;
+        dpy_set_ui_info(dcl.con, &nudge, FALSE);
+        [self updateUIInfoLocked];
+    });
+}
