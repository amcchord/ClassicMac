+/*
+ * ClassicMac: live toggle for the classic input helpers (right-click as
+ * Control+click, scroll wheel as arrow keys). Mirrors the "Right-click &
+ * scroll wheel helpers" per-VM setting in the host app, which decides the
+ * state the machine starts with; this menu item changes the running
+ * session only, e.g. right after installing USB Overdrive in the guest.
+ */
+- (void)toggleInputHelpers:(id)sender
+{
+    bool enabled = !(right_click_ctrl || scroll_keys);
+    right_click_ctrl = enabled;
+    scroll_keys = enabled;
+    if (enabled) {
+        [sender setState: NSControlStateValueOn];
+    } else {
+        [sender setState: NSControlStateValueOff];
+    }
+}
