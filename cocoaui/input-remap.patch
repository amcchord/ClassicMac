+/*
+ * scroll-keys=on: translate wheel motion into arrow-key taps (the same
+ * approach SheepShaver takes), because classic Mac OS mouse drivers ignore
+ * both wheel buttons and the USB HID wheel axis. Called with the BQL held
+ * (from handleEventLocked).
+ */
+- (bool) handleScrollAsArrowKeys:(NSEvent *)event
+{
+    QKeyCode code;
+    int taps = 0;
+    int i;
+
+    if ([event hasPreciseScrollingDeltas]) {
+        /* Trackpad and Magic Mouse: accumulate the point-based deltas and
+         * emit roughly one arrow tap per 20 points of travel, carrying the
+         * remainder so slow scrolling still gets through. */
+        scrollKeysAccum += [event scrollingDeltaY];
+        taps = (int)(scrollKeysAccum / 20);
+        scrollKeysAccum -= taps * 20;
+    } else if ([event deltaY] != 0) {
+        /* Discrete wheel: three lines per notch, like SheepShaver. */
+        if ([event deltaY] > 0) {
+            taps = 3;
+        } else {
+            taps = -3;
+        }
+    }
+
+    if (taps > 0) {
+        code = Q_KEY_CODE_UP;
+    } else {
+        code = Q_KEY_CODE_DOWN;
+        taps = -taps;
+    }
+    if (taps > 9) {
+        taps = 9; /* keep fast flicks from flooding the guest */
+    }
+    for (i = 0; i < taps; i++) {
+        qkbd_state_key_event(kbd, code, true);
+        qkbd_state_key_event(kbd, code, false);
+    }
+    return true;
+}
+
+/*
+ * right-click-ctrl=on: classic Mac OS has no secondary mouse button;
+ * contextual menus open with Control+click. Deliver the right button as a
+ * left click with a synthesized Control key that stays down until the
+ * button is released, so menu tracking (click, hold, release over an item)
+ * works. handleEventLocked's modifier sync knows not to lift it while
+ * rightClickCtrlHeld is set.
+ */
+- (void) handleRightClickAsControlClick:(NSEvent *)event down:(bool)down
+{
+    if (!isMouseGrabbed) {
+        return;
+    }
+
+    with_bql(^{
+        if (down) {
+            self->rightClickCtrlHeld = TRUE;
+            qkbd_state_key_event(kbd, Q_KEY_CODE_CTRL, true);
+        }
+        qemu_input_queue_btn(dcl.con, INPUT_BUTTON_LEFT, down);
+    });
+
+    /* forwards the pointer position and syncs the queued button change */
+    [self handleMouseEvent:event];
+
+    if (!down) {
+        with_bql(^{
+            qkbd_state_key_event(kbd, Q_KEY_CODE_CTRL, false);
+            self->rightClickCtrlHeld = FALSE;
+        });
+    }
+}
