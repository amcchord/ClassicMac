+/*
+ * ClassicMac: user-facing names for this machine process. The bundle name
+ * comes from the wrapping helper app ("Quadra 800" / "Power Mac G4"); the
+ * machine name is the -name option (the machine's name in the library).
+ */
+static NSString *classicmac_bundle_name(void)
+{
+    NSString *bundleName = [[NSBundle mainBundle] objectForInfoDictionaryKey:@"CFBundleName"];
+    if (bundleName) {
+        return bundleName;
+    }
+    return @"Classic Macintosh";
+}
+
+static NSString *classicmac_machine_name(void)
+{
+    if (qemu_name) {
+        return [NSString stringWithUTF8String:qemu_name];
+    }
+    return classicmac_bundle_name();
+}
 
