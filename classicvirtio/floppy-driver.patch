+
+static void refreshMedia(bool postEvent) {
+	struct config *config = VConfig;
+	uint64_t capacity = config->capacity;
+	bool inserted = capacity != 0;
+	bool wasInserted = dqe.diskInPlace != 0;
+
+	firstblock = 0;
+	numblocks = capacity > UINT32_MAX ? UINT32_MAX : capacity;
+	dqe.driveSize = numblocks;
+	dqe.driveS1 = numblocks >> 16;
+	dqe.diskInPlace = inserted ? 1 : 0;
+
+	printf("Device size: %#llx bytes, %#llx blocks\n", capacity*512, capacity);
+	if (inserted && !postEvent) {
+		probePartitions(&firstblock, &numblocks);
+		dqe.driveSize = numblocks;
+		dqe.driveS1 = numblocks >> 16;
+	}
+
+	if (postEvent && inserted != wasInserted) {
+		PostEvent(diskEvt, dqe.dQDrive);
+	}
