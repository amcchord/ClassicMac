+	uint32_t size[2] = {
+		sizeof fixedbuf->request,
+		sizeof fixedbuf->reply,
+	};
+	QSend(0, 1, 1, phys, size, NULL, true/*wait*/);
+	return fixedbuf->reply == 0 ? noErr : ioErr;
+}
