     /* hardware mouse cursor support */
     uint32_t invalidated_y_table[VGA_MAX_HEIGHT / 32];
diff --git a/include/hw/display/bochs-vbe.h b/include/hw/display/bochs-vbe.h
index 6b12539..bbaf590 100644
--- a/include/hw/display/bochs-vbe.h
+++ b/include/hw/display/bochs-vbe.h
@@ -79,4 +79,14 @@
 #define PCI_VGA_QEXT_REG_REQ_HEIGHT   (3 * 4)
 #define PCI_VGA_QEXT_REG_REQ_SERIAL   (4 * 4)
 
+/*
+ * Feature bitmap (present when REG_SIZE reads at least
+ * PCI_VGA_QEXT_SIZE_FEATURES). Lets the guest video driver detect
+ * optional device capabilities before relying on them.
+ */
+#define PCI_VGA_QEXT_SIZE_FEATURES    (6 * 4)
+#define PCI_VGA_QEXT_REG_FEATURES     (5 * 4)
+/* packed linear 1/2/4 bpp indexed modes (packed-lowbpp=on) */
+#define  PCI_VGA_QEXT_FEATURE_PACKED_LOWBPP  0x1
+
