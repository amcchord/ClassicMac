@@ -455,6 +457,7 @@ static const Property vga_pci_properties[] = {
     DEFINE_PROP_BIT("edid",
                     PCIVGAState, flags, PCI_VGA_FLAG_ENABLE_EDID, true),
     DEFINE_PROP_BOOL("host-resize", PCIVGAState, host_resize, false),
