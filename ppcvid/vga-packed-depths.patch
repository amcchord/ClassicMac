     DEFINE_EDID_PROPERTIES(PCIVGAState, edid_info),
 };
 
diff --git a/hw/display/vga_int.h b/hw/display/vga_int.h
index d7fe348..0bf5177 100644
--- a/hw/display/vga_int.h
+++ b/hw/display/vga_int.h
@@ -136,6 +136,13 @@ typedef struct VGACommonState {
     bool full_update_gfx;
     bool big_endian_fb;
     bool default_endian_fb;
+    /*
+     * packed-lowbpp=on: DISPI bpp values 1/2/4 select packed linear
+     * indexed modes (big-endian bit order within each byte, leftmost
+     * pixel in the most significant bits) as used by classic Mac OS,
+     * instead of being rejected (1/2) or mapped to planar VGA (4).
+     */
+    bool packed_lowbpp;
