diff --git a/hw/display/vga.c b/hw/display/vga.c
index ee7d97b..26f214c 100644
--- a/hw/display/vga.c
+++ b/hw/display/vga.c
@@ -566,6 +566,15 @@ static void vbe_fixup_regs(VGACommonState *s)
 
     /* check depth */
     switch (r[VBE_DISPI_INDEX_BPP]) {
+    case 1:
+    case 2:
+        /* packed linear sub-byte modes: only with packed-lowbpp=on */
+        if (s->packed_lowbpp) {
+            bits = r[VBE_DISPI_INDEX_BPP];
+        } else {
+            bits = r[VBE_DISPI_INDEX_BPP] = 8;
+        }
+        break;
     case 4:
     case 8:
     case 16:
@@ -662,7 +671,7 @@ static void vbe_update_vgaregs(VGACommonState *s)
     s->cr[VGA_CRTC_OVERFLOW] |= 0x10;
     s->cr[VGA_CRTC_MAX_SCAN] |= 0x40;
 
-    if (s->vbe_regs[VBE_DISPI_INDEX_BPP] == 4) {
+    if (s->vbe_regs[VBE_DISPI_INDEX_BPP] == 4 && !s->packed_lowbpp) {
         shift_control = 0;
         s->sr_vbe[VGA_SEQ_CLOCK_MODE] &= ~8; /* no double line */
     } else {
@@ -1378,6 +1387,52 @@ static void vga_draw_text(VGACommonState *s, int full_update)
     }
 }
 
+/*
+ * Packed linear sub-byte indexed modes (packed-lowbpp=on). Bit order is
+ * big-endian within each byte - the leftmost pixel lives in the most
+ * significant bits - matching the classic Mac OS framebuffer layout at
+ * 1, 2 and 4 bits per pixel. Colors come from the DAC palette, so the
+ * guest drives them through the usual 0x3c8/0x3c9 registers.
+ */
+static void *vga_draw_line1_packed(VGACommonState *vga, uint8_t *d,
+                                   uint32_t addr, int width, int hpel)
+{
+    uint32_t *palette = vga->last_palette;
+    int x;
+
+    for (x = 0; x < width; x++) {
+        uint8_t b = vga_read_byte(vga, addr + (x >> 3));
+        ((uint32_t *)d)[x] = palette[(b >> (7 - (x & 7))) & 0x1];
+    }
+    return NULL;
+}
+
+static void *vga_draw_line2_packed(VGACommonState *vga, uint8_t *d,
+                                   uint32_t addr, int width, int hpel)
+{
+    uint32_t *palette = vga->last_palette;
+    int x;
+
+    for (x = 0; x < width; x++) {
+        uint8_t b = vga_read_byte(vga, addr + (x >> 2));
+        ((uint32_t *)d)[x] = palette[(b >> ((3 - (x & 3)) * 2)) & 0x3];
+    }
+    return NULL;
+}
+
+static void *vga_draw_line4_packed(VGACommonState *vga, uint8_t *d,
+                                   uint32_t addr, int width, int hpel)
+{
+    uint32_t *palette = vga->last_palette;
+    int x;
+
+    for (x = 0; x < width; x++) {
+        uint8_t b = vga_read_byte(vga, addr + (x >> 1));
+        ((uint32_t *)d)[x] = palette[(b >> ((1 - (x & 1)) * 4)) & 0xf];
+    }
+    return NULL;
+}
+
 enum {
     VGA_DRAW_LINE2,
     VGA_DRAW_LINE2D2,
@@ -1385,6 +1440,9 @@ enum {
     VGA_DRAW_LINE4D2,
     VGA_DRAW_LINE8D2,
     VGA_DRAW_LINE8,
+    VGA_DRAW_LINE1_PACKED,
+    VGA_DRAW_LINE2_PACKED,
+    VGA_DRAW_LINE4_PACKED,
     VGA_DRAW_LINE15_LE,
     VGA_DRAW_LINE16_LE,
     VGA_DRAW_LINE24_LE,
@@ -1403,6 +1461,9 @@ static vga_draw_line_func * const vga_draw_line_table[VGA_DRAW_LINE_NB] = {
     vga_draw_line4d2,
     vga_draw_line8d2,
     vga_draw_line8,
+    vga_draw_line1_packed,
+    vga_draw_line2_packed,
+    vga_draw_line4_packed,
     vga_draw_line15_le,
     vga_draw_line16_le,
     vga_draw_line24_le,
@@ -1549,6 +1610,23 @@ static void vga_draw_graphic(VGACommonState *s, int full_update)
             v = VGA_DRAW_LINE8D2;
             bits = 4;
             break;
+        case 1:
+            /* only reachable with packed-lowbpp=on (see vbe_fixup_regs) */
+            full_update |= update_palette256(s);
+            v = VGA_DRAW_LINE1_PACKED;
+            bits = 1;
+            break;
+        case 2:
+            full_update |= update_palette256(s);
+            v = VGA_DRAW_LINE2_PACKED;
+            bits = 2;
+            break;
+        case 4:
+            /* shift_control == 2 with bpp 4 implies packed-lowbpp=on */
+            full_update |= update_palette256(s);
+            v = VGA_DRAW_LINE4_PACKED;
+            bits = 4;
+            break;
         case 8:
             full_update |= update_palette256(s);
             v = VGA_DRAW_LINE8;
