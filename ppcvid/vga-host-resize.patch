+/*
+ * QEXT read handler used when host-resize is enabled. Only registered from
+ * the vga-pci realize paths, so the VGACommonState is known to be embedded
+ * in a PCIVGAState (unlike virtio-vga, which shares pci_vga_qext_ops).
+ */
+static uint64_t pci_vga_qext_resize_read(void *ptr, hwaddr addr,
+                                         unsigned size)
+{
+    VGACommonState *s = ptr;
+    PCIVGAState *d = container_of(s, PCIVGAState, vga);
+
+    switch (addr) {
+    case PCI_VGA_QEXT_REG_SIZE:
+        return PCI_VGA_QEXT_SIZE_RESIZE;
+    case PCI_VGA_QEXT_REG_REQ_WIDTH:
+        return d->host_req_width;
+    case PCI_VGA_QEXT_REG_REQ_HEIGHT:
+        return d->host_req_height;
+    case PCI_VGA_QEXT_REG_REQ_SERIAL:
+        return d->host_req_serial;
+    default:
+        return pci_vga_qext_read(ptr, addr, size);
+    }
+}
