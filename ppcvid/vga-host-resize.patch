+/*
+ * UI callback for host-window-driven live resizing (host-resize=on): the
+ * display frontend reports the desired guest resolution (e.g. the Cocoa
+ * window size on drag end); we latch it into the host-request registers and
+ * bump the serial. The guest video driver polls the serial and switches to
+ * the requested mode; nothing is forced from the host side.
+ */
+static void pci_std_vga_host_resize_request(PCIVGAState *d,
+                                            uint32_t w, uint32_t h)
+{
+    if (w == 0 || h == 0) {
+        return; /* no geometry hint in this update */
+    }
+    if (w > VBE_DISPI_MAX_XRES) {
+        w = VBE_DISPI_MAX_XRES;
+    }
+    if (h > VBE_DISPI_MAX_YRES) {
+        h = VBE_DISPI_MAX_YRES;
+    }
+    if (d->host_req_width == w && d->host_req_height == h) {
+        return; /* unchanged: don't nudge the guest */
+    }
+    d->host_req_width = w;
+    d->host_req_height = h;
+    d->host_req_serial++;
+}
+
+static void pci_std_vga_ui_info(void *opaque, uint32_t idx, QemuUIInfo *info)
+{
+    VGACommonState *s = opaque;
+    PCIVGAState *d = container_of(s, PCIVGAState, vga);
+
+    pci_std_vga_host_resize_request(d, info->width, info->height);
+}
+
+/*
+ * Write-only QOM property mirroring the ui_info path, so a resize request
+ * can be injected from the monitor (qom-set ... host-resize-request WxH)
+ * for scripting and testing without a windowing UI.
+ */
+static void pci_std_vga_set_host_resize_request(Object *obj, const char *value,
+                                                Error **errp)
+{
+    PCIVGAState *d = PCI_VGA(PCI_DEVICE(obj));
+    unsigned int w, h;
+
+    if (!d->host_resize) {
+        error_setg(errp, "host-resize is disabled on this device");
+        return;
+    }
+    if (sscanf(value, "%ux%u", &w, &h) != 2 || w == 0 || h == 0) {
+        error_setg(errp, "expected WIDTHxHEIGHT");
+        return;
+    }
+    pci_std_vga_host_resize_request(d, w, h);
+}
+
 static void pci_std_vga_realize(PCIDevice *dev, Error **errp)
 {
     PCIVGAState *d = PCI_VGA(dev);
@@ -247,6 +356,13 @@ static void pci_std_vga_realize(PCIDevice *dev, Error **errp)
     vga_init(s, OBJECT(dev), pci_address_space(dev), pci_address_space_io(dev),
              true);
 
+    if (d->host_resize) {
+        /* Wrap the standard ops with a ui_info hook for live resizing. */
+        d->host_resize_ops = *s->hw_ops;
+        d->host_resize_ops.ui_info = pci_std_vga_ui_info;
+        s->hw_ops = &d->host_resize_ops;
+    }
+
     s->con = graphic_console_init(DEVICE(dev), 0, s->hw_ops, s);
 
     /* XXX: VGA_RAM_SIZE must be a power of two */
@@ -265,7 +381,7 @@ static void pci_std_vga_realize(PCIDevice *dev, Error **errp)
             edid = true;
         }
         pci_std_vga_mmio_region_init(s, OBJECT(dev), &d->mmio, d->mrs,
-                                     qext, edid);
+                                     qext, edid, d->host_resize);
 
         pci_register_bar(&d->dev, 2, PCI_BASE_ADDRESS_SPACE_MEMORY, &d->mmio);
     }
@@ -295,7 +411,8 @@ static void pci_secondary_vga_realize(PCIDevice *dev, Error **errp)
     if (d->flags & (1 << PCI_VGA_FLAG_ENABLE_EDID)) {
         edid = true;
     }
-    pci_std_vga_mmio_region_init(s, OBJECT(dev), &d->mmio, d->mrs, qext, edid);
+    pci_std_vga_mmio_region_init(s, OBJECT(dev), &d->mmio, d->mrs, qext, edid,
+                                 false);
 
     pci_register_bar(&d->dev, 0, PCI_BASE_ADDRESS_MEM_PREFETCH, &s->vram);
     pci_register_bar(&d->dev, 2, PCI_BASE_ADDRESS_SPACE_MEMORY, &d->mmio);
@@ -337,6 +454,7 @@ static const Property vga_pci_properties[] = {
                     PCIVGAState, flags, PCI_VGA_FLAG_ENABLE_QEXT, true),
     DEFINE_PROP_BIT("edid",
                     PCIVGAState, flags, PCI_VGA_FLAG_ENABLE_EDID, true),
+    DEFINE_PROP_BOOL("host-resize", PCIVGAState, host_resize, false),
     DEFINE_EDID_PROPERTIES(PCIVGAState, edid_info),
 };
 
@@ -389,6 +507,10 @@ static void vga_class_init(ObjectClass *klass, const void *data)
     /* Expose framebuffer byteorder via QOM */
     object_class_property_add_bool(klass, "big-endian-framebuffer",
                                    vga_get_big_endian_fb, vga_set_big_endian_fb);
+
+    /* Test/scripting hook for the host-resize channel */
+    object_class_property_add_str(klass, "host-resize-request",
+                                  NULL, pci_std_vga_set_host_resize_request);
 }
 
