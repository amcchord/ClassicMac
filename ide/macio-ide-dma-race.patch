+static int macio_ide_post_load(void *opaque, int version_id)
+{
+    MACIOIDEState *m = opaque;
+    DBDMAState *dbdma = m->dbdma;
+    DBDMA_io *io = &dbdma->channels[m->channel].io;
+
+    if (version_id < 6) {
+        m->dma_unit = m->bus.unit;
+        m->dma_completion_pending = false;
+        m->dma_completion_atapi = false;
+    }
+
+    if (m->dma_unit >= ARRAY_SIZE(m->bus.ifs) ||
+        m->dma_completion_pending != timer_pending(m->dma_completion_timer) ||
+        (m->dma_completion_pending &&
+         (!m->dma_active || !io->processing))) {
+        return -EINVAL;
+    }
+
+    return 0;
+}
