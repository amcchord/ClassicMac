 /* MacIO based PowerPC IDE */
 
 #define MACIO_PAGE_SIZE 4096
+#define MACIO_IDE_DEFAULT_COMPLETION_DELAY_NS (1 * SCALE_MS)
+
+static IDEState *pmac_ide_dma_state(MACIOIDEState *m)
+{
+    if (m->dma_active || m->dma_completion_pending) {
+        return &m->bus.ifs[m->dma_unit];
+    }
+
+    return ide_bus_active_if(&m->bus);
+}
+
+static void pmac_ide_complete(void *opaque)
+{
+    MACIOIDEState *m = opaque;
+    DBDMAState *dbdma = m->dbdma;
+    DBDMA_io *io = &dbdma->channels[m->channel].io;
+    IDEState *s = &m->bus.ifs[m->dma_unit];
+
+    assert(m->dma_completion_pending);
+    trace_pmac_ide_completion(m, s->unit, m->dma_completion_atapi,
+                              m->dma_completion_delay_ns);
+
+    m->dma_completion_pending = false;
+    m->dma_active = false;
+
+    if (m->dma_completion_atapi) {
+        ide_atapi_cmd_ok(s);
+    } else {
+        s->status = READY_STAT | SEEK_STAT;
+        ide_bus_set_irq(s->bus);
+    }
+
+    ide_set_inactive(s, false);
+    io->dma_end(io);
+}
+
+static void pmac_ide_complete_pending(MACIOIDEState *m)
+{
+    if (!m->dma_completion_pending) {
+        return;
+    }
+
+    timer_del(m->dma_completion_timer);
+    pmac_ide_complete(m);
+}
+
+static bool pmac_ide_delay_completion(MACIOIDEState *m, IDEState *s,
+                                      bool atapi)
+{
+    if (!m->dma_completion_delay_ns) {
+        return false;
+    }
+
+    assert(!m->dma_completion_pending);
+    m->dma_completion_pending = true;
+    m->dma_completion_atapi = atapi;
+    s->bus->dma->aiocb = NULL;
+
+    /*
+     * Real block-backed MacIO DMA cannot finish in the same scheduling
+     * window in which the guest starts it.  With a cached host image QEMU
+     * can do exactly that, racing classic Mac OS before its synchronous I/O
+     * wait is armed.  Keep the terminal descriptor active briefly, then
+     * publish the IDE and DBDMA completions together from the timer callback.
+     */
+    trace_pmac_ide_completion_scheduled(m, s->unit, atapi,
+                                        m->dma_completion_delay_ns);
+    timer_mod(m->dma_completion_timer,
+              qemu_clock_get_ns(QEMU_CLOCK_VIRTUAL) +
+              m->dma_completion_delay_ns);
+    return true;
+}
 
