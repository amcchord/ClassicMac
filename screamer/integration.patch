+    sysbus_connect_irq(sbd, 2,
+                       qdev_get_gpio_in(pic_dev, NEWWORLD_SCREAMER_RX_IRQ));
+    macio_screamer_register_dma(&s->screamer, &s->dbdma, 0x10, 0x12);
