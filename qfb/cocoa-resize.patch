@@ -1411,6 +1424,24 @@
 - (void)windowDidResize:(NSNotification *)notification
 {
     [cocoaView updateBounds];
+    /*
+     * While the user is actively dragging the window edge, just rescale the
+     * existing guest framebuffer to fill the new frame (updateBounds) and do
+     * NOT ask the guest to switch resolution on every intermediate size. We
+     * push a single request when the drag ends (windowDidEndLiveResize), so the
+     * guest performs exactly one Display Manager switch to the final pixel size
+     * rather than churning through dozens of sizes mid-drag. Non-live changes
+     * (zoom, programmatic resizes) still report immediately here.
+     */
+    if (![cocoaView inLiveResize]) {
+        [cocoaView updateUIInfo];
+    }
+}
+
+- (void)windowDidEndLiveResize:(NSNotification *)notification
+{
+    /* The user finished dragging: report the final window size so the guest
+     * switches its resolution to match exactly (see qfb_periodic). */
     [cocoaView updateUIInfo];
 }
 
