+static void virtio_blk_change_media(void *opaque, bool load, Error **errp)
+{
+    VirtIOBlock *s = opaque;
+
+    s->eject_requested = false;
+    s->tray_open = !load;
+
+    if (!load) {
+        blk_set_perm(s->blk, 0, BLK_PERM_ALL, &error_abort);
+        s->original_wce = false;
+    } else {
+        if (!blkconf_apply_backend_options(&s->conf.conf,
+                                           !blk_supports_write_perm(s->blk),
+                                           true, errp)) {
+            return;
+        }
+        if (!blkconf_geometry(&s->conf.conf, NULL, 65535, 255, 255, errp) ||
+            !blkconf_blocksizes(&s->conf.conf, errp)) {
+            return;
+        }
+        s->original_wce = blk_enable_write_cache(s->blk);
+    }
+
+    virtio_blk_resize(s);
+}
